<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="350" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <Image Source="/Images/logo.png" Width="50"></Image>
            <Label >Логин:</Label>
            <TextBox x:Name="txtLogin"></TextBox>
            <Label >Пароль:</Label>
            <PasswordBox Height="25" x:Name="txtPassword"></PasswordBox>
            <Button Margin="0,10" Click="LoginButton">Войти</Button>
            <Button Click="GuestButton">Войти как гость</Button>
        </StackPanel>
    </Grid>
</Window>