<Window x:Class="demo.EquipmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:demo"
        Title="{Binding WindowTitle}" Height="700" Width="600"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="{Binding WindowTitle}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <GroupBox Grid.Row="1" Header="Фотография" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Grid.Row="0" 
                           x:Name="imgEquipment" 
                           Source="{Binding PhotoPath}" 
                           Stretch="Uniform" 
                           Width="300" 
                           Height="200" 
                           Margin="10"
                           HorizontalAlignment="Center"/>

                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="10"
                                Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}">
                        <Button Content="Выбрать фото" 
                                Click="SelectPhotoButton_Click" 
                                Margin="5"
                                Padding="10,5"/>
                        <Button Content="Удалить фото" 
                                Click="DeletePhotoButton_Click" 
                                Margin="5"
                                Padding="10,5"
                                Background="#FF4444"
                                Foreground="White"
                                Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Наименование" Margin="0,0,0,10">
                <TextBox x:Name="txtName" 
                        Text="{Binding EquipmentName}" 
                        IsReadOnly="{Binding IsReadOnly}"
                        Background="{Binding FieldBackground}"
                        Height="30"
                        Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="Инвентарный номер" Margin="0,0,0,10">
                <TextBox x:Name="txtInventoryNumber" 
                        Text="{Binding InventoryNumber}" 
                        IsReadOnly="True"
                        Background="#F0F0F0"
                        Height="30"
                        Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Описание" Margin="0,0,0,10">
                <TextBox x:Name="txtDescription" 
                        Text="{Binding Description}" 
                        IsReadOnly="{Binding IsReadOnly}"
                        Background="{Binding FieldBackground}"
                        Height="80"
                        TextWrapping="Wrap"
                        Margin="5"
                        AcceptsReturn="True"/>
            </GroupBox>

            <GroupBox Grid.Row="5" Header="Подразделение" Margin="0,0,0,10">
                <ComboBox x:Name="cmbOffice" 
                         ItemsSource="{Binding Offices}"
                         DisplayMemberPath="FullName"
                         SelectedValuePath="OfficeId"
                         SelectedValue="{Binding OfficeId}"
                         IsEnabled="{Binding CanSelectOffice}"
                         Height="30"
                         Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Row="6" Header="Кабинет" Margin="0,0,0,10">
                <ComboBox x:Name="cmbRoom" 
                         ItemsSource="{Binding Rooms}"
                         DisplayMemberPath="RoomNumber"
                         SelectedValuePath="RoomId"
                         SelectedValue="{Binding RoomId}"
                         IsEnabled="{Binding CanEdit}"
                         Height="30"
                         Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Row="7" Header="Вес (кг)" Margin="0,0,0,10">
                <TextBox x:Name="txtWeight" 
                        Text="{Binding Weight}" 
                        IsReadOnly="{Binding IsReadOnly}"
                        Background="{Binding FieldBackground}"
                        Height="30"
                        Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Row="8" Header="Нормативный срок службы (лет)" Margin="0,0,0,10">
                <TextBox x:Name="txtServiceLife" 
                        Text="{Binding ServiceLifeYears}" 
                        IsReadOnly="{Binding IsReadOnly}"
                        Background="{Binding FieldBackground}"
                        Height="30"
                        Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Row="9" Header="Дата постановки на баланс" Margin="0,0,0,10">
                <DatePicker x:Name="dpRegistrationDate" 
                           SelectedDate="{Binding RegistrationDate}"
                           IsEnabled="False"
                           Background="#F0F0F0"
                           Height="30"
                           Margin="5"/>
            </GroupBox>

            <StackPanel Grid.Row="10" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,0">

                <Button Content="Сохранить" 
                        Click="SaveButton_Click" 
                        Margin="10"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        Width="100"
                        Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}"/>

                <Button
                        Click="DeleteButton_Click" 
                        Margin="10"
                        Background="#FF4444"
                        Foreground="White"
                        FontWeight="Bold"
                        Width="100"
                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}">Удалить</Button>

                <Button
                        Click="CloseButton_Click" 
                        Margin="10"
                        Background="#808080"
                        Foreground="White"
                        FontWeight="Bold"
                        Width="100">Закрыть</Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>