<Window x:Class="demo.EquipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:demo"
        Title="Окно просмотра оборудования" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Выход"
                    Click="ExitButton"
                    Margin="5"/>

            <Button Grid.Column="1"
                    Content="Добавить оборудование"
                    Click="AddEquipmentButton"
                    Margin="5"
                    Visibility="{Binding CanAddEdit, Converter={StaticResource BoolToVis}}"
                    Background="#4CAF50"/>

            <TextBlock Grid.Column="2"
                       x:Name="txtUserInfo"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="5"/>
        </Grid>

        <Grid Grid.Row="1" 
              Margin="10" 
              VerticalAlignment="Center"
              Visibility="{Binding CanUseFilters, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="5">
                <TextBlock Text="Поиск:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSearch" 
                         TextChanged="txtSearch_TextChanged"
                         Height="25"
                         ToolTip="Введите текст для поиска по всем текстовым полям"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="5">
                <TextBlock Text="Фильтр по подразделению:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbOfficeFilter" 
                          SelectionChanged="cmbOfficeFilter_SelectionChanged"
                          Height="25"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="OfficeId"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Vertical" Margin="5">
                <TextBlock Text="Сортировка по весу:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbSortOrder" 
                          SelectionChanged="cmbSortOrder_SelectionChanged"
                          Height="25">
                    <ComboBoxItem Tag="None">Без сортировки</ComboBoxItem>
                    <ComboBoxItem Tag="Ascending">По возрастанию</ComboBoxItem>
                    <ComboBoxItem Tag="Descending">По убыванию</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ListView x:Name="lvEquipment"
              HorizontalAlignment="Center"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              MouseDoubleClick="lvEquipment_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Width="600" BorderThickness="1" BorderBrush="#FFA500" Margin="0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.7*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0" 
                               Source="{Binding PhotoImage, FallbackValue=/Images/stub.jpg, TargetNullValue=/Images/stub.jpg}"
                               Stretch="UniformToFill"
                               Width="150"
                               Height="150"/>

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding Name}"  
                                       HorizontalAlignment="Center" 
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,5"/>

                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding Description}" 
                                       Margin="0,5"/>

                                    <Border Visibility="{Binding DataContext.CanSeeStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                                    Background="{Binding StatusColor}" 
                                    Padding="7,5"
                                    CornerRadius="3">
                                        <TextBlock Text="{Binding StatusText}" 
                                           HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                                    </Border>

                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding Room, TargetNullValue='', StringFormat=Аудитория: {0}}"
                                       Margin="0,5"
                                       Visibility="{Binding HasRoom, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding Office, TargetNullValue='', StringFormat=Подразделение: {0}}"
                                       Margin="0,5"
                                       Visibility="{Binding HasOffice, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding InventoryNumber, TargetNullValue='', StringFormat=Инв. номер: {0}}"
                                       Margin="0,5"/>

                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding Weight, StringFormat=Вес: {0} кг}"
                                       Margin="0,5"/>

                                    <TextBlock TextWrapping="Wrap" 
                                       Text="{Binding RegistrationDate, StringFormat=Дата постановки: dd.MM.yyyy}"
                                       Margin="0,5"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Window>