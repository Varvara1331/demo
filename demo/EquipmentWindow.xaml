<Window x:Class="demo.EquipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:demo"
        Title="Окно просмотра оборудования" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                        Content="Выход"
                        Click="ExitButton"/>

            <TextBlock Grid.Column="1"
                           x:Name="txtUserInfo"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Center">
            <ListView x:Name="lvEquipment" Width="780">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Width="600" BorderThickness="1" BorderBrush="#FFA500" Margin="0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.7*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0" 
                                       Source="{Binding Photo}"
                                       Stretch="UniformToFill"/>

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock TextWrapping="Wrap" 
                                               Text="{Binding Name}"  
                                               HorizontalAlignment="Center" 
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,5"/>

                                    <TextBlock TextWrapping="Wrap" 
                                               Text="{Binding Description}" 
                                               Margin="0,5"/>

                                    <Border Visibility="{Binding DataContext.CanSeeStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                                            Background="{Binding StatusColor}" 
                                            Padding="7,15"
                                            CornerRadius="3">
                                        <TextBlock Text="{Binding StatusText}" 
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"/>
                                    </Border>

                                    <TextBlock TextWrapping="Wrap" 
                                               Text="{Binding Room, TargetNullValue='', StringFormat=Аудитория: {0}}"
                                               Margin="0,5"/>

                                    <TextBlock TextWrapping="Wrap" 
                                               Text="{Binding Office, TargetNullValue='', StringFormat=Подразделение: {0}}"
                                               Margin="0,5"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>